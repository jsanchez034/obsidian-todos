{
  "name": "obsidian-todos",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18",
      "@testing-library/react": "^16.3.0",
      "@testing-library/jest-dom": "^6.6.3",
      "@testing-library/user-event": "^14.6.1",
      "jsdom": "^26.1.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:desktop": "turbo -F desktop dev",
    "build:desktop": "turbo -F desktop build:stable",
    "build:desktop:canary": "turbo -F desktop build:canary",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@obsidian-todos/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@obsidian-todos/config": "workspace:*",
    "@vitest/coverage-v8": "^3.2.1",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.9.6",
    "typescript": "^5",
    "vitest": "^3.2.1"
  },
  "packageManager": "bun@1.3.11"
}
